<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚗 Vehicle Parking Registration"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Vehicle Type Spinner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vehicle Type"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerVehicleType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- Vehicle Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vehicle Number"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etVehicleNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:hint="e.g. KA-01-AB-1234"
            android:inputType="textCapCharacters"
            android:layout_marginBottom="16dp"/>

        <!-- RC Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RC Number"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etRCNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:hint="e.g. RC123456789"
            android:inputType="textCapCharacters"
            android:layout_marginBottom="24dp"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SUBMIT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_bg"
            android:layout_marginBottom="24dp"/>

        <!-- Details Card (hidden initially) -->
        <LinearLayout
            android:id="@+id/cardDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Registration Details"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1A237E"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vehicle Type:"
                    android:textColor="#546E7A"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvDetailVehicleType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vehicle Number:"
                    android:textColor="#546E7A"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvDetailVehicleNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RC Number:"
                    android:textColor="#546E7A"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvDetailRCNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Confirm / Edit Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="EDIT"
                    android:textColor="#1A237E"
                    android:background="@drawable/button_outline_bg"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnConfirm"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="CONFIRM"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_bg"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>