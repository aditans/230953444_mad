<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update Order Details"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Delivery Zone" />

        <Spinner
            android:id="@+id/updateSpinnerZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Delivery Type" />

        <RadioGroup
            android:id="@+id/updateRgDeliveryType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioButton android:id="@+id/updateRbStandard" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Standard Delivery" />
            <RadioButton android:id="@+id/updateRbExpress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Express Delivery" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Payment Method" />

        <RadioGroup
            android:id="@+id/updateRgPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioButton android:id="@+id/updateRbCash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cash on Delivery" />
            <RadioButton android:id="@+id/updateRbCredit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Credit Card" />
            <RadioButton android:id="@+id/updateRbUPI" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UPI" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/updateCbCutlery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Include Cutlery" />

        <TimePicker
            android:id="@+id/updateTimePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner" />

        <Button
            android:id="@+id/btnSaveUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save Changes" />

    </LinearLayout>
</ScrollView>