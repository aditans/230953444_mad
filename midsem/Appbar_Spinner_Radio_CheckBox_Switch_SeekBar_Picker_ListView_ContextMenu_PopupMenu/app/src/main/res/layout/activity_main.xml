<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Event Registration"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Increased spacer for camera cutout -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

            <!-- Section 1: Category Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Category"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Section 2: Ticket Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Ticket Type"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_ticket_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_general"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="General" />

                <RadioButton
                    android:id="@+id/rb_vip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIP" />
            </RadioGroup>

            <EditText
                android:id="@+id/et_promo_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Promo Code"
                android:visibility="visible" />

            <!-- Section 3: Add-Ons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Add-Ons"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cb_tshirt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T-Shirt" />

            <RadioGroup
                android:id="@+id/rg_tshirt_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <RadioButton
                    android:id="@+id/rb_s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S" />

                <RadioButton
                    android:id="@+id/rb_m"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M" />

                <RadioButton
                    android:id="@+id/rb_l"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="L" />

                <RadioButton
                    android:id="@+id/rb_xl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XL" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/cb_lunch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunch" />

            <RadioGroup
                android:id="@+id/rg_meal_pref"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <RadioButton
                    android:id="@+id/rb_veg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Veg" />

                <RadioButton
                    android:id="@+id/rb_nonveg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Non-Veg" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/cb_certificate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Certificate" />

            <CheckBox
                android:id="@+id/cb_vip_lounge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIP Lounge"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/cb_event_kit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Kit" />

            <!-- Section 4: Reminders -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_reminders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Enable Event Reminders" />

            <!-- Section 5: Attendance Slot -->
            <Button
                android:id="@+id/btn_pick_slot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Pick Attendance Slot" />

            <TextView
                android:id="@+id/tv_slot_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No reminder set." />

            <!-- Section 6: Guest Count -->
            <TextView
                android:id="@+id/tv_guest_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Guests: 0 / 10"
                android:textSize="16sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sb_guests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10" />

            <!-- Section 7: Payment Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Payment Method"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_payment_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rb_upi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPI" />

                <RadioButton
                    android:id="@+id/rb_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Card" />

                <RadioButton
                    android:id="@+id/rb_pay_at_venue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pay at Venue" />
            </RadioGroup>

            <EditText
                android:id="@+id/et_upi_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter UPI ID"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_card_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Card Number"
                android:inputType="number"
                android:visibility="gone" />

            <!-- Register Button -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Register" />

            <!-- Section 8: Registrations List -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Recent Registrations"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/lv_registrations"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>